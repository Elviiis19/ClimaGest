{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Information about the professional using the system",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "subscriptionPlan": { "type": "string", "enum": ["free", "monthly", "quarterly", "semiannual", "annual"] },
        "subscriptionStatus": { "type": "string", "enum": ["active", "inactive", "trial"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "subscriptionPlan", "subscriptionStatus", "createdAt"]
    },
    "Client": {
      "title": "Client",
      "description": "A client belonging to the professional",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "email": { "type": "string" },
        "document": { "type": "string" },
        "type": { "type": "string", "enum": ["residential", "commercial"] },
        "lastServiceDate": { "type": "string" },
        "returnPreference": { "type": "string" },
        "nextReturnDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "phone", "address", "createdAt"]
    },
    "Equipment": {
      "title": "Equipment",
      "description": "An equipment belonging to the professional (linked to a client)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "clientId": { "type": "string" },
        "brand": { "type": "string" },
        "modelType": { "type": "string" },
        "capacityBTU": { "type": "number" },
        "environment": { "type": "string" },
        "location": { "type": "string" },
        "serialNumber": { "type": "string" },
        "installDate": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "clientId", "brand", "modelType", "capacityBTU", "createdAt"]
    },
    "MaintenanceRecord": {
      "title": "MaintenanceRecord",
      "description": "A maintenance record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "equipmentId": { "type": "string" },
        "clientId": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "technician": { "type": "string" },
        "value": { "type": "number" },
        "nextRecommendation": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "equipmentId", "clientId", "date", "type", "createdAt"]
    },
    "FinancialTransaction": {
      "title": "FinancialTransaction",
      "description": "Income or expense",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["revenue", "expense"] },
        "description": { "type": "string" },
        "value": { "type": "number" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["paid", "pending"] },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "description", "value", "date", "status", "category", "createdAt"]
    },
    "Scheduling": {
      "title": "Scheduling",
      "description": "An appointment/service schedule",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "clientId": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "canceled"] },
        "value": { "type": "number" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "clientId", "date", "time", "description", "status", "value", "createdAt"]
    },
    "Budget": {
      "title": "Budget",
      "description": "A budget/quote",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "clientId": { "type": "string" },
        "date": { "type": "string" },
        "items": { "type": "array" },
        "totalValue": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "sent", "approved", "rejected"] },
        "validUntil": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "clientId", "date", "items", "totalValue", "status", "createdAt"]
    },
    "StockItem": {
      "title": "StockItem",
      "description": "Inventory item",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "minQuantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "supplier": { "type": "string" },
        "partNumber": { "type": "string" },
        "location": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "category", "quantity", "minQuantity", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Professional user profiles"
    },
    "/users/{userId}/clients/{clientId}": {
      "schema": { "$ref": "#/entities/Client" },
      "description": "Clients belonging to a user"
    },
    "/users/{userId}/equipments/{equipmentId}": {
      "schema": { "$ref": "#/entities/Equipment" },
      "description": "Equipments belonging to a user"
    },
    "/users/{userId}/records/{recordId}": {
      "schema": { "$ref": "#/entities/MaintenanceRecord" },
      "description": "Service records belonging to a user"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/FinancialTransaction" },
      "description": "Financial items belonging to a user"
    },
    "/users/{userId}/schedulings/{schedulingId}": {
      "schema": { "$ref": "#/entities/Scheduling" },
      "description": "Schedules belonging to a user"
    },
    "/users/{userId}/budgets/{budgetId}": {
      "schema": { "$ref": "#/entities/Budget" },
      "description": "Budgets belonging to a user"
    },
    "/users/{userId}/stock/{stockItemId}": {
      "schema": { "$ref": "#/entities/StockItem" },
      "description": "Stock items belonging to a user"
    }
  }
}
