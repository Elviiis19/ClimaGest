rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['email', 'subscriptionPlan', 'subscriptionStatus', 'createdAt']) &&
             data.email is string && data.email.size() <= 200 &&
             data.subscriptionPlan in ['free', 'monthly', 'quarterly', 'semiannual', 'annual'] &&
             data.subscriptionStatus in ['active', 'inactive', 'trial'];
    }

    function isValidClient(data) {
      return data.keys().hasAll(['userId', 'name', 'phone', 'address', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 200 &&
             data.phone is string && data.phone.size() <= 50 &&
             data.address is string && data.address.size() <= 500;
    }

    function isValidEquipment(data) {
      return data.keys().hasAll(['userId', 'clientId', 'brand', 'modelType', 'capacityBTU', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.clientId is string && data.clientId.size() <= 128 &&
             data.brand is string && data.brand.size() <= 100 &&
             data.modelType is string && data.modelType.size() <= 100 &&
             data.capacityBTU is number;
    }

    function isValidMaintenanceRecord(data) {
      return data.keys().hasAll(['userId', 'equipmentId', 'clientId', 'date', 'type', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.equipmentId is string && data.equipmentId.size() <= 128 &&
             data.clientId is string && data.clientId.size() <= 128 &&
             data.date is string && data.date.size() <= 50 &&
             data.type is string && data.type.size() <= 100;
    }

    function isValidFinancialTransaction(data) {
      return data.keys().hasAll(['userId', 'type', 'description', 'value', 'date', 'status', 'category', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.type in ['revenue', 'expense'] &&
             data.description is string && data.description.size() <= 500 &&
             data.value is number &&
             data.date is string && data.date.size() <= 50 &&
             data.status in ['paid', 'pending'] &&
             data.category is string && data.category.size() <= 100;
    }

    function isValidScheduling(data) {
      return data.keys().hasAll(['userId', 'clientId', 'date', 'time', 'description', 'status', 'value', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.clientId is string && data.clientId.size() <= 128 &&
             data.date is string && data.date.size() <= 50 &&
             data.time is string && data.time.size() <= 50 &&
             data.description is string && data.description.size() <= 500 &&
             data.status in ['pending', 'completed', 'canceled'] &&
             data.value is number;
    }

    function isValidBudget(data) {
      return data.keys().hasAll(['userId', 'clientId', 'date', 'items', 'totalValue', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.clientId is string && data.clientId.size() <= 128 &&
             data.date is string && data.date.size() <= 50 &&
             data.items is list && data.items.size() <= 50 &&
             data.totalValue is number &&
             data.status in ['draft', 'sent', 'approved', 'rejected'];
    }

    function isValidStockItem(data) {
      return data.keys().hasAll(['userId', 'name', 'category', 'quantity', 'minQuantity', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.quantity is number &&
             data.minQuantity is number;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      // We might allow creation with exact keys
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUserProfile(incoming()) && incoming().createdAt == request.time && incoming().subscriptionPlan == "free";
      // Subscription updates should likely be done by a backend webhook, but for now we might lock it or allow specific updates
      // Here we allow updating basic fields, but prevent changing subscription info
      allow update: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUserProfile(incoming()) && incoming().createdAt == existing().createdAt && incoming().subscriptionPlan == existing().subscriptionPlan && incoming().subscriptionStatus == existing().subscriptionStatus;
      allow delete: if false;

      match /clients/{clientId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(clientId) && isValidClient(incoming()) && incoming().createdAt == request.time;
        allow update: if isSignedIn() && request.auth.uid == userId && isValidId(clientId) && isValidClient(incoming()) && incoming().createdAt == existing().createdAt && incoming().userId == existing().userId;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /equipments/{equipmentId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(equipmentId) && isValidEquipment(incoming()) && incoming().createdAt == request.time;
        allow update: if isSignedIn() && request.auth.uid == userId && isValidId(equipmentId) && isValidEquipment(incoming()) && incoming().createdAt == existing().createdAt && incoming().userId == existing().userId;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /records/{recordId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(recordId) && isValidMaintenanceRecord(incoming()) && incoming().createdAt == request.time;
        allow update: if isSignedIn() && request.auth.uid == userId && isValidId(recordId) && isValidMaintenanceRecord(incoming()) && incoming().createdAt == existing().createdAt && incoming().userId == existing().userId;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /transactions/{transactionId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(transactionId) && isValidFinancialTransaction(incoming()) && incoming().createdAt == request.time;
        allow update: if isSignedIn() && request.auth.uid == userId && isValidId(transactionId) && isValidFinancialTransaction(incoming()) && incoming().createdAt == existing().createdAt && incoming().userId == existing().userId;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /schedulings/{schedulingId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(schedulingId) && isValidScheduling(incoming()) && incoming().createdAt == request.time;
        allow update: if isSignedIn() && request.auth.uid == userId && isValidId(schedulingId) && isValidScheduling(incoming()) && incoming().createdAt == existing().createdAt && incoming().userId == existing().userId;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /budgets/{budgetId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(budgetId) && isValidBudget(incoming()) && incoming().createdAt == request.time;
        allow update: if isSignedIn() && request.auth.uid == userId && isValidId(budgetId) && isValidBudget(incoming()) && incoming().createdAt == existing().createdAt && incoming().userId == existing().userId;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /stock/{stockItemId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(stockItemId) && isValidStockItem(incoming()) && incoming().createdAt == request.time;
        allow update: if isSignedIn() && request.auth.uid == userId && isValidId(stockItemId) && isValidStockItem(incoming()) && incoming().createdAt == existing().createdAt && incoming().userId == existing().userId;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
